# ========================
# DATABASE
# ========================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/jobflow"

# ========================
# AUTH (NextAuth.js v5)
# ========================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-in-production-use-openssl-rand-base64-32"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub OAuth
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ========================
# AI
# ========================
ANTHROPIC_API_KEY=""

# ========================
# STORAGE (Cloudflare R2)
# ========================
CLOUDFLARE_R2_ACCOUNT_ID=""
CLOUDFLARE_R2_ACCESS_KEY_ID=""
CLOUDFLARE_R2_SECRET_ACCESS_KEY=""
CLOUDFLARE_R2_BUCKET_NAME="jobflow-docs"

# ========================
# EMAIL (Resend)
# ========================
RESEND_API_KEY=""

# ========================
# QUEUE (Redis / BullMQ)
# ========================
REDIS_URL="redis://localhost:6379"

# ========================
# BILLING (Stripe)
# ========================
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRO_PRICE_ID=""

# ========================
# EMAIL INTEGRATION (Gmail OAuth)
# ========================
GOOGLE_GMAIL_CLIENT_ID=""
GOOGLE_GMAIL_CLIENT_SECRET=""

# ========================
# SERVER
# ========================
PORT=3001
NODE_ENV="development"

# Production only
API_URL="https://api.jobflow.ai"
